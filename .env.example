# 仅供本地开发。复制为 .env 后请自行替换；不得用于生产环境。
POSTGRES_DB=testweave
POSTGRES_USER=testweave
POSTGRES_PASSWORD=local-development-only-change-me
POSTGRES_PORT=5432

TESTWEAVE_ENVIRONMENT=development
TESTWEAVE_LOG_LEVEL=INFO
TESTWEAVE_DATABASE_URL=postgresql+psycopg://testweave:local-development-only-change-me@127.0.0.1:5432/testweave
TESTWEAVE_DATABASE_CONNECT_TIMEOUT_SECONDS=5
TESTWEAVE_DATABASE_POOL_TIMEOUT_SECONDS=5
TESTWEAVE_DATABASE_STATEMENT_TIMEOUT_MS=5000
TESTWEAVE_MIGRATION_STATEMENT_TIMEOUT_MS=900000
TESTWEAVE_MIGRATION_LOCK_TIMEOUT_MS=10000
TESTWEAVE_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# 仅供本地开发的占位加密主密钥。生产必须通过秘密管理注入至少 32 字符的高熵随机值，严禁复用此值。
TESTWEAVE_SECRET_KEY=local-development-only-secret-key-change-me
# 使用 SSH 仓库时填写受信任 known_hosts 文件的绝对路径；不要关闭主机密钥校验。
TESTWEAVE_GIT_KNOWN_HOSTS_FILE=

# 留空时客户端通过 Vite 同源代理访问服务端。
VITE_API_BASE_URL=
